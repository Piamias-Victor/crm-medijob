# Database (Neon en prod, Postgres local/docker en dev)
# Local docker: postgresql://postgres:postgres@localhost:5432/medijob?schema=public
DATABASE_URL=

# NextAuth v5 — générer un secret : `openssl rand -base64 32`
# AUTH_SECRET est lu nativement par NextAuth v5 ; NEXTAUTH_SECRET reste supporté.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Seed users (dev) — laisser vide pour utiliser les mots de passe par défaut
# documentés dans docs/handoffs/HANDOFF_ISSUE_053.md
SEED_ADMIN_PASSWORD=
SEED_RECRUTEUR_PASSWORD=

# Assistant IA / extraction — provider abstrait (SPEC_V2 §7), via OpenRouter
# EXTRACTION_PROVIDER=mock → réponses simulées, aucune clé requise (tests / dev)
# Sinon (toute autre valeur) → OpenRouter si OPENROUTER_API_KEY est défini, sinon fallback mock
EXTRACTION_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Modèle OpenRouter (défaut : google/gemini-2.5-flash-lite)
EXTRACTION_MODEL=google/gemini-2.5-flash-lite
